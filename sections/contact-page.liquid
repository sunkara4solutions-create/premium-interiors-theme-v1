<section class="contact-page">
  <div class="contact-page-inner">

    <div class="contact-info">
      <div class="section-label">{{ section.settings.label }}</div>
      <h1 class="section-title contact-section-title">{{ section.settings.heading }}</h1>
      <p class="contact-intro">{{ section.settings.intro }}</p>

      <div class="contact-details">
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9742;</span>
          <div>
            <div class="contact-detail-label">Phone</div>
            <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}" class="contact-detail-value">{{ section.settings.phone }}</a>
          </div>
        </div>
        {% if section.settings.email != blank %}
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9993;</span>
          <div>
            <div class="contact-detail-label">Email</div>
            <a href="mailto:{{ section.settings.email }}" class="contact-detail-value">{{ section.settings.email }}</a>
          </div>
        </div>
        {% endif %}
        {% if section.settings.address != blank %}
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9679;</span>
          <div>
            <div class="contact-detail-label">Address</div>
            <div class="contact-detail-value">{{ section.settings.address | newline_to_br }}</div>
          </div>
        </div>
        {% endif %}
        {% if section.settings.hours != blank %}
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9711;</span>
          <div>
            <div class="contact-detail-label">Hours</div>
            <div class="contact-detail-value">{{ section.settings.hours | newline_to_br }}</div>
          </div>
        </div>
        {% endif %}
      </div>
    </div>

    <div class="contact-form-wrap">
      <h2 class="contact-form-title">{{ section.settings.form_heading }}</h2>
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="contact-success">Thank you! We'll be in touch shortly.</p>
        {% else %}
          {% if form.errors %}
            <p class="contact-error">{{ form.errors | default_errors }}</p>
          {% endif %}
          <div class="contact-field">
            <label for="contact-name">Name</label>
            <input type="text" id="contact-name" name="contact[name]" value="{{ form.name }}" required>
          </div>
          <div class="contact-field">
            <label for="contact-email">Email</label>
            <input type="email" id="contact-email" name="contact[email]" value="{{ form.email }}" required>
          </div>
          <div class="contact-field">
            <label for="contact-phone">Phone (optional)</label>
            <input type="tel" id="contact-phone" name="contact[phone]" value="{{ form.phone }}">
          </div>
          <div class="contact-field">
            <label for="contact-message">Message</label>
            <textarea id="contact-message" name="contact[body]" rows="5" required>{{ form.body }}</textarea>
          </div>
          <button type="submit" class="btn-primary">Send Message</button>
        {% endif %}
      {% endform %}
    </div>

  </div>
</section>

<style>
.contact-page {
  background: #1c1208;
  padding: 80px 5%;
}
.contact-page-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.contact-section-title { color: #f5f0e8 !important; }
.contact-intro {
  font-size: 0.88rem;
  line-height: 1.95;
  color: #7a6558;
  font-weight: 300;
  margin-bottom: 2.5rem;
}
.contact-details {
  display: flex;
  flex-direction: column;
  gap: 1.6rem;
}
.contact-detail-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.contact-detail-icon {
  font-size: 1.2rem;
  color: #c9a040;
  margin-top: 2px;
  flex-shrink: 0;
}
.contact-detail-label {
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #7a6558;
  margin-bottom: 0.2rem;
}
.contact-detail-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.15rem;
  font-weight: 300;
  color: #f5f0e8;
  text-decoration: none;
}
.contact-detail-value a { color: #f5f0e8; text-decoration: none; }
.contact-detail-value a:hover { color: #c9a040; }

.contact-form-wrap {
  background: #2c2520;
  padding: 40px;
  border: 1px solid rgba(201,160,64,0.18);
}
.contact-form-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 300;
  color: #f5f0e8;
  margin-bottom: 1.8rem;
}
.contact-field {
  margin-bottom: 1.2rem;
}
.contact-field label {
  display: block;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #7a6558;
  margin-bottom: 0.4rem;
}
.contact-field input,
.contact-field textarea {
  width: 100%;
  background: #1c1208;
  border: 1px solid rgba(201,160,64,0.25);
  color: #f5f0e8;
  padding: 0.75rem 1rem;
  font-family: 'Jost', sans-serif;
  font-size: 0.88rem;
  outline: none;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.contact-field input:focus,
.contact-field textarea:focus {
  border-color: #c9a040;
}
.contact-field textarea { resize: vertical; }
.contact-success {
  color: #c9a040;
  font-size: 0.95rem;
  padding: 1rem 0;
}
.contact-error {
  color: #c96e6e;
  font-size: 0.85rem;
  margin-bottom: 1rem;
}
@media (max-width: 768px) {
  .contact-page-inner {
    grid-template-columns: 1fr;
    gap: 50px;
  }
}
</style>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Get In Touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact Us" },
    { "type": "textarea", "id": "intro", "label": "Intro Text", "default": "We'd love to help you find the perfect panels for your space. Local to Arizona — reach out and we'll get back to you fast." },
    { "type": "text", "id": "phone", "label": "Phone Number", "default": "832-856-0777" },
    { "type": "text", "id": "email", "label": "Email Address" },
    { "type": "textarea", "id": "address", "label": "Address (optional)" },
    { "type": "textarea", "id": "hours", "label": "Business Hours (optional)" },
    { "type": "text", "id": "form_heading", "label": "Form Heading", "default": "Send Us a Message" }
  ],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
