<section class="contact-page">
  <div class="contact-page-inner">

    <div class="contact-info">
      <div class="contact-label-tag">Get In Touch</div>
      <h1 class="contact-heading">{{ section.settings.heading }}</h1>
      <p class="contact-intro">{{ section.settings.intro }}</p>

      <div class="contact-details">
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9742;</span>
          <div>
            <div class="contact-detail-label">Phone / Text</div>
            <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}" class="contact-detail-value">{{ section.settings.phone }}</a>
          </div>
        </div>
        {% if section.settings.email != blank %}
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9993;</span>
          <div>
            <div class="contact-detail-label">Email</div>
            <a href="mailto:{{ section.settings.email }}" class="contact-detail-value">{{ section.settings.email }}</a>
          </div>
        </div>
        {% endif %}
        {% if section.settings.address != blank %}
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9679;</span>
          <div>
            <div class="contact-detail-label">Location</div>
            <div class="contact-detail-value">{{ section.settings.address | newline_to_br }}</div>
          </div>
        </div>
        {% endif %}
        {% if section.settings.hours != blank %}
        <div class="contact-detail-item">
          <span class="contact-detail-icon">&#9711;</span>
          <div>
            <div class="contact-detail-label">Business Hours</div>
            <div class="contact-detail-value">{{ section.settings.hours | newline_to_br }}</div>
          </div>
        </div>
        {% endif %}

        <div class="contact-local-note">
          <strong>&#9679; Serving Peoria &amp; Phoenix Metro, AZ</strong>
          Local pickup available — no shipping wait.
        </div>
      </div>
    </div>

    <div class="contact-form-wrap">
      <h2 class="contact-form-title">{{ section.settings.form_heading }}</h2>
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="contact-success">&#10003; Thank you! We'll be in touch shortly.</p>
        {% else %}
          {% if form.errors %}
            <p class="contact-error">{{ form.errors | default_errors }}</p>
          {% endif %}
          <div class="contact-field">
            <label for="contact-name">Your Name</label>
            <input type="text" id="contact-name" name="contact[name]" value="{{ form.name }}" placeholder="Jane Smith" required>
          </div>
          <div class="contact-field">
            <label for="contact-email">Email Address</label>
            <input type="email" id="contact-email" name="contact[email]" value="{{ form.email }}" placeholder="jane@email.com" required>
          </div>
          <div class="contact-field">
            <label for="contact-phone">Phone Number (optional)</label>
            <input type="tel" id="contact-phone" name="contact[phone]" value="{{ form.phone }}" placeholder="832-555-0000">
          </div>
          <div class="contact-field">
            <label for="contact-message">Your Message</label>
            <textarea id="contact-message" name="contact[body]" rows="5" placeholder="Tell us about your project, room size, or questions about the panels..." required>{{ form.body }}</textarea>
          </div>
          <button type="submit" class="btn-primary contact-submit-btn">Send Message</button>
        {% endif %}
      {% endform %}
    </div>

  </div>
</section>

<style>
.contact-page {
  background: #fdf9f4;
  padding: 100px 5% 80px;
}
.contact-page-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 80px;
  align-items: start;
}
.contact-label-tag {
  font-size: 0.72rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: #c9a040;
  margin-bottom: 1.2rem;
  display: block;
}
.contact-heading {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.8rem, 5vw, 4.5rem);
  font-weight: 300;
  line-height: 1.1;
  color: #1c1208;
  margin-bottom: 1.5rem;
}
.contact-intro {
  font-size: 1rem;
  line-height: 1.9;
  color: #7a6558;
  font-weight: 300;
  margin-bottom: 3rem;
  max-width: 400px;
}
.contact-details {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
.contact-detail-item {
  display: flex;
  align-items: flex-start;
  gap: 1.2rem;
}
.contact-detail-icon {
  font-size: 1.5rem;
  color: #c9a040;
  margin-top: 2px;
  flex-shrink: 0;
}
.contact-detail-label {
  font-size: 0.68rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #7a6558;
  margin-bottom: 0.35rem;
}
.contact-detail-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 300;
  color: #1c1208;
  text-decoration: none;
  display: block;
  line-height: 1.3;
}
.contact-detail-value:hover { color: #c9a040; }

.contact-local-note {
  background: linear-gradient(135deg, #f0e8d8, #f5ede0);
  border-left: 3px solid #c9a040;
  padding: 1.2rem 1.5rem;
  font-size: 0.9rem;
  color: #7a6558;
  line-height: 1.7;
  margin-top: 1rem;
}
.contact-local-note strong {
  display: block;
  color: #1c1208;
  font-size: 0.95rem;
  font-weight: 500;
  margin-bottom: 0.2rem;
}

.contact-form-wrap {
  background: #ffffff;
  padding: 50px;
  border: 1px solid rgba(201,160,64,0.25);
  box-shadow: 0 4px 40px rgba(28,16,8,0.07);
}
.contact-form-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 300;
  color: #1c1208;
  margin-bottom: 2rem;
}
.contact-field {
  margin-bottom: 1.5rem;
}
.contact-field label {
  display: block;
  font-size: 0.72rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #7a6558;
  margin-bottom: 0.5rem;
  font-weight: 500;
}
.contact-field input,
.contact-field textarea {
  width: 100%;
  background: #fdf9f4;
  border: 1.5px solid rgba(28,16,8,0.15);
  color: #1c1208;
  padding: 0.9rem 1.1rem;
  font-family: 'Jost', sans-serif;
  font-size: 0.95rem;
  outline: none;
  box-sizing: border-box;
  transition: border-color 0.2s, box-shadow 0.2s;
  border-radius: 0;
}
.contact-field input::placeholder,
.contact-field textarea::placeholder {
  color: #b0a090;
}
.contact-field input:focus,
.contact-field textarea:focus {
  border-color: #c9a040;
  box-shadow: 0 0 0 3px rgba(201,160,64,0.1);
}
.contact-field textarea { resize: vertical; }
.contact-submit-btn {
  width: 100%;
  padding: 1.2rem;
  font-size: 0.82rem;
  letter-spacing: 0.25em;
  margin-top: 0.5rem;
}
.contact-success {
  background: #f0f7f0;
  border: 1px solid rgba(80,160,80,0.3);
  color: #3a7a3a;
  font-size: 1rem;
  padding: 1.2rem 1.5rem;
  border-radius: 2px;
}
.contact-error {
  background: #fff0f0;
  border: 1px solid rgba(200,80,80,0.2);
  color: #a03030;
  font-size: 0.88rem;
  padding: 0.8rem 1rem;
  margin-bottom: 1rem;
}
@media (max-width: 768px) {
  .contact-page { padding: 80px 5% 60px; }
  .contact-page-inner { grid-template-columns: 1fr; gap: 50px; }
  .contact-form-wrap { padding: 30px 20px; }
  .contact-heading { font-size: 2.6rem; }
}
</style>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact Us" },
    { "type": "textarea", "id": "intro", "label": "Intro Text", "default": "We'd love to help you find the perfect panels for your space. Local to Arizona — reach out and we'll get back to you fast." },
    { "type": "text", "id": "phone", "label": "Phone Number", "default": "832-856-0777" },
    { "type": "text", "id": "email", "label": "Email Address" },
    { "type": "textarea", "id": "address", "label": "Address (optional)" },
    { "type": "textarea", "id": "hours", "label": "Business Hours (optional)" },
    { "type": "text", "id": "form_heading", "label": "Form Heading", "default": "Send Us a Message" }
  ],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
