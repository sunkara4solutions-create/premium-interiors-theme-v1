<section class="cta-banner">
  <div class="section-label" style="display:inline-block">{{ section.settings.label }}</div>
  <h2 class="section-title" style="margin-bottom:0.8rem">{{ section.settings.heading }}</h2>
  <p class="cta-sub">{{ section.settings.subtext }}</p>
  <a href="{{ section.settings.button_url }}" class="btn-primary">{{ section.settings.button_text }}</a>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Limited Time" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "All Panels 25% Off While Stock Lasts" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Shop the Sale" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "CTA Banner" }]
}
{% endschema %}
