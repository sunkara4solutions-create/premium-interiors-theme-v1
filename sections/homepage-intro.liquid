<section class="intro" id="about">
  <div class="intro-visual">
    {% if section.settings.intro_image %}
      <img src="{{ section.settings.intro_image | img_url: '800x' }}" alt="Wood Panel" class="intro-real-image" />
    {% else %}
      <div class="intro-panel-mock">
        <div class="intro-slats">
          {% for i in (1..16) %}<div class="slat"></div>{% endfor %}
        </div>
        <div class="intro-glow-overlay"></div>
      </div>
    {% endif %}
    <div class="intro-badge">
      <strong>25%</strong>
      OFF Sale
    </div>
  </div>

  <div class="intro-text">
    <div class="section-label">{{ section.settings.label }}</div>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="intro-body">{{ section.settings.body | newline_to_br }}</div>
    <div class="intro-stats">
      <div>
        <div class="stat-num">25%</div>
        <div class="stat-label">Noise Reduction</div>
      </div>
      <div>
        <div class="stat-num">{{ collections.all.products_count }}</div>
        <div class="stat-label">Premium Products</div>
      </div>
      <div>
        <div class="stat-num">30<span style="font-size:1rem">min</span></div>
        <div class="stat-label">Avg. Install Time</div>
      </div>
      <div>
        <div class="stat-num">5★</div>
        <div class="stat-label">Customer Rating</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homepage Intro",
  "settings": [
    { "type": "image_picker", "id": "intro_image", "label": "Panel Image (optional)" },
    { "type": "text", "id": "label", "label": "Label", "default": "About Our Panels" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Crafted for the Discerning Eye" },
    { "type": "textarea", "id": "body", "label": "Body Text" }
  ],
  "presets": [{ "name": "Homepage Intro" }]
}
{% endschema %}
