<div class="product-page">
  <div class="product-page-inner">

    <!-- IMAGES -->
    <div class="product-gallery">
      <div class="product-gallery-main" id="gallery-main">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | img_url: '900x' }}"
            alt="{{ product.featured_image.alt | escape }}"
            id="main-product-image"
            class="gallery-main-img"
          />
        {% else %}
          <div class="gallery-placeholder">
            <div class="intro-slats">{% for i in (1..16) %}<div class="slat"></div>{% endfor %}</div>
          </div>
        {% endif %}
      </div>

      {% if product.images.size > 1 %}
        <div class="product-gallery-thumbs">
          {% for image in product.images %}
            <img
              src="{{ image | img_url: '200x' }}"
              alt="{{ image.alt | escape }}"
              class="gallery-thumb {% if forloop.first %}active{% endif %}"
              data-src="{{ image | img_url: '900x' }}"
              onclick="setMainImage(this)"
            />
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- INFO -->
    <div class="product-info-col">
      <div class="section-label" style="margin-bottom:0.5rem">{{ product.type | default: 'Acoustic Wood Panel' }}</div>
      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-price-display">
        {% if product.compare_at_price > product.price %}
          <span class="price-sale large">{{ product.price | money }}</span>
          <span class="price-original large">{{ product.compare_at_price | money }}</span>
          {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
          <span class="price-tag">{{ savings }}% Off</span>
        {% else %}
          <span class="price-sale large">{{ product.price | money }}</span>
        {% endif %}
      </div>

      <!-- LOCAL PICKUP BANNER -->
      <div class="local-pickup-banner">
        <span class="local-pickup-icon">📍</span>
        <div class="local-pickup-text">
          <strong>Local Pickup &amp; Phoenix Metro Delivery</strong>
          Pickup available in Peoria, AZ &nbsp;·&nbsp; Local delivery across the Phoenix area &nbsp;·&nbsp; Questions? Call or text <a href="tel:8328560777" style="color:#dbb458">832-856-0777</a>
        </div>
      </div>

      {% if product.description != blank %}
        <div class="product-description">{{ product.description }}</div>
      {% endif %}

      <!-- PANEL SPECS -->
      <div class="product-specs">
        <div class="product-specs-title">Panel Specifications</div>
        <div class="spec-row">
          <span class="spec-label">Panel Size</span>
          <span class="spec-value">10ft × 2ft (118" × 24")</span>
        </div>
        <div class="spec-row">
          <span class="spec-label">Coverage Area</span>
          <span class="spec-value">20 sq ft per panel</span>
        </div>
        <div class="spec-row">
          <span class="spec-label">Thickness</span>
          <span class="spec-value">0.75 inches</span>
        </div>
        <div class="spec-row">
          <span class="spec-label">Material</span>
          <span class="spec-value">Acoustic Wood Slat</span>
        </div>
        <div class="spec-row">
          <span class="spec-label">Finish</span>
          <span class="spec-value">Natural Wood Veneer</span>
        </div>
      </div>

      <!-- INSTALLATION INFO -->
      <div class="install-info">
        <div class="install-info-title">Installation</div>
        <ul>
          <li>Adhesive, nail, or screw mount — works on any flat wall</li>
          <li>Tongue-and-groove system — no visible fasteners</li>
          <li>Panels can be cut to size with a standard saw</li>
          <li>Suitable for drywall, concrete, and wood stud walls</li>
          <li>One person can install a full accent wall in under 30 min</li>
        </ul>
      </div>

      {% form 'product', product, id: 'product-form' %}
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="product-option">
              <label class="option-label">{{ option.name }}</label>
              <div class="option-values">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="option-btn {% if option.selected_value == value %}active{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                    onclick="selectOption(this)"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}

        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}" />

        <div class="product-qty-row">
          <div class="qty-control">
            <button type="button" onclick="changeQty(-1)">−</button>
            <input type="number" name="quantity" id="qty-input" value="1" min="1" />
            <button type="button" onclick="changeQty(1)">+</button>
          </div>
        </div>

        <button
          type="submit"
          name="add"
          class="btn-primary add-to-cart-btn"
          {% unless product.available %}disabled{% endunless %}
        >
          {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
        </button>

      {% endform %}

      <div class="product-meta-list">
        <div class="meta-item">✓ Local pickup in Peoria, AZ</div>
        <div class="meta-item">✓ Phoenix metro delivery available</div>
        <div class="meta-item">✓ LED channel routing included</div>
        <div class="meta-item">✓ 30-day hassle-free returns</div>
        <div class="meta-item">✓ Call or text us: <a href="tel:8328560777" style="color:var(--gold)">832-856-0777</a></div>
      </div>
    </div>
  </div>
</div>

<script>
  function setMainImage(thumb) {
    document.getElementById('main-product-image').src = thumb.dataset.src;
    document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  function changeQty(delta) {
    const input = document.getElementById('qty-input');
    const val = Math.max(1, parseInt(input.value) + delta);
    input.value = val;
  }

  const variants = {{ product.variants | json }};

  function selectOption(btn) {
    btn.closest('.option-values').querySelectorAll('.option-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    matchVariant();
  }

  function matchVariant() {
    const selected = Array.from(document.querySelectorAll('.option-btn.active')).map(b => b.dataset.value);
    const match = variants.find(v => v.options.every((o, i) => o === selected[i]));
    if (match) {
      document.getElementById('variant-id').value = match.id;
    }
  }
</script>

{% schema %}
{
  "name": "Product Main",
  "settings": [],
  "presets": [{ "name": "Product Main" }]
}
{% endschema %}
