{% assign article = article %}
<article style="max-width:800px;margin:60px auto;padding:0 20px;">
  <h1 style="font-size:2rem;margin-bottom:20px;">{{ article.title }}</h1>
  <div style="line-height:1.8;font-size:1rem;color:#333;">
    {{ article.content }}
  </div>
  <div style="margin-top:40px;">
    <a href="/collections/all" style="background:#000;color:#fff;padding:12px 24px;text-decoration:none;border-radius:4px;">Shop Wood Panels</a>
  </div>
</article>